# GitHub Packages auth for @twelvelabs-io/react (npm/bun only — NOT loaded by Next.js)
#
# LOCAL (pick one):
#   A) Global (set once):  %USERPROFILE%\.cursor\secrets\.env.registry
#   B) Repo fallback:      copy this file to .env.registry in repo root
#
# Load before npm install:
#   . .\scripts\load-registry-env.ps1
#   cd app && npm install
#
# VERCEL / CI (required for deploy): set REGISTRY_TOKEN as a project secret.
# Public GitHub repos never commit the token — only app/.npmrc with ${REGISTRY_TOKEN}.

REGISTRY_TOKEN=
